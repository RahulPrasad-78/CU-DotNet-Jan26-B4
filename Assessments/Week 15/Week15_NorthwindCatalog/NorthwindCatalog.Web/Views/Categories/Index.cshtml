@model List<CategoryDto>

@{
    int imgIndex = 1;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Browse Categories</h2>
        <p class="text-muted mb-0">Select a category to view available products.</p>
    </div>
    <span class="badge text-bg-secondary">@Model.Count categories</span>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
            <div class="card h-100 shadow-sm border-0">
                <img src="@Url.Content($"~/images/{imgIndex}.jpeg")" class="card-img-top" style="height: 180px; object-fit: cover;" />

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-3">@item.CategoryName</h5>

                    <a href="/Product/ByCategory/@item.CategoryId" class="btn btn-primary mt-auto w-100">
                        View Products
                    </a>
                </div>
            </div>
        </div>

        imgIndex++;

        if (imgIndex > 8)
        {
            imgIndex = 1;
        }
    }
</div>