@model VagaBond.MVC.Models.Destination

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">Edit Destination</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(excludePropertyErrors: true)
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="CityName" class="form-label"></label>
                    <input asp-for="CityName" class="form-control" />
                    <div class="text-danger">@Html.ValidationMessageFor(m => m.CityName)</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Country" class="form-label"></label>
                    <input asp-for="Country" class="form-control" />
                    <div class="text-danger">@Html.ValidationMessageFor(m => m.Country)</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <div class="text-danger">@Html.ValidationMessageFor(m => m.Description)</div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Rating" class="form-label"></label>
                        <input asp-for="Rating" class="form-control" type="number" min="0" max="10" />
                        <div class="text-danger">@Html.ValidationMessageFor(m => m.Rating)</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastVisted" class="form-label"></label>
                        <input asp-for="LastVisted" class="form-control" type="date" />
                        <div class="text-danger">@Html.ValidationMessageFor(m => m.LastVisted)</div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
