@model VagaBond.MVC.Models.Destination

<div class="container mt-4">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Confirm Delete</h5>
        </div>
        <div class="card-body">
            <p class="mb-3">Are you sure you want to delete the following destination?</p>
            <dl class="row">
                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@Model.CityName</dd>

                <dt class="col-sm-3">Country</dt>
                <dd class="col-sm-9">@Model.Country</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>

            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>
    </div>
</div>
