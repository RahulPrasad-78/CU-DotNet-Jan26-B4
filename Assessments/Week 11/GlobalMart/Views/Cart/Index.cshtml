@model IEnumerable<GlobalMart.Models.Cart>
@using System.Linq

@{
    ViewData["Title"] = "Cart";
}

<div class="container py-4">
    <h2 class="mb-4">Your Cart</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <div class="display-6 text-muted">🛒</div>
            <p class="lead mt-3">Your cart is empty. Start adding great products!</p>
            <a class="btn btn-primary" asp-controller="Product" asp-action="Index">Browse products</a>
        </div>
    }
    else
    {
        var total = Model.Sum(i => i.Price);

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@item.Name</div>
                                        <div class="text-muted small">@item.Price.ToString("C")</div>
                                    </div>
                                    <div class="text-end">
                                        <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                                               @* Remove action not implemented yet *@
                                            <button class="btn btn-outline-danger btn-sm" disabled>Remove</button>
                                        </form>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <div>Subtotal</div>
                            <div>@total.ToString("C")</div>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <div>Shipping</div>
                            <div>Free</div>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="fs-5">Total</div>
                            <div class="fs-5 fw-bold">@total.ToString("C")</div>
                        </div>

                        <a class="btn btn-primary w-100 mb-2">Proceed to checkout</a>
                        <a class="btn btn-outline-secondary w-100" asp-controller="Product" asp-action="Index">Continue shopping</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
