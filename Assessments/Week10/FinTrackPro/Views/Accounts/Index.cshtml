@model IEnumerable<FinTrackPro.Models.Account>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Account Name</th>
            <th>Balance</th>
            <th>Transactions</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AccountName</td>

                <td>@item.Balance</td>

                <td>
                    <select class="form-control">
                        @if (item.Transactions != null && item.Transactions.Any())
                        {
                            foreach (var t in item.Transactions)
                            {
                                <option>@t.Description - @t.Amount</option>
                            }
                        }
                        else
                        {
                            <option>No Transactions</option>
                        }
                    </select>
                </td>

                <td>
                    <a asp-action="CreateTransaction" asp-route-id="@item.Id">
                        Add Transaction
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>