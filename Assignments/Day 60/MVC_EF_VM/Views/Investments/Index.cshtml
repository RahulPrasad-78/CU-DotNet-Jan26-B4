@model IEnumerable<MVC_EF_VM.Models.Investment>

@{
    ViewData["Title"] = "Investments";
    var totalSum = Model?.Sum(i => i.PurchasePrice * i.Quantity) ?? 0m;
}

<div class="container my-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Investments</h5>
                    <a class="btn btn-primary btn-sm" asp-action="Create" role="button">Create New</a>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Html.DisplayNameFor(model => model.TickerSymbol)</th>
                                    <th>@Html.DisplayNameFor(model => model.AssetName)</th>
                                    <th class="text-end">@Html.DisplayNameFor(model => model.PurchasePrice)</th>
                                    <th class="text-end">@Html.DisplayNameFor(model => model.Quantity)</th>
                                    <th>@Html.DisplayNameFor(model => model.PurchaseDate)</th>
                                    <th class="text-end">Total Value</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.TickerSymbol)</td>
                                            <td>@Html.DisplayFor(modelItem => item.AssetName)</td>
                                            <td class="text-end">@item.PurchasePrice.ToString("C")</td>
                                            <td class="text-end">@item.Quantity</td>
                                            <td>@item.PurchaseDate.ToString("d")</td>
                                            <td class="text-end">@((item.PurchasePrice * item.Quantity).ToString("C"))</td>
                                            <td class="text-center">
                                                <div class="btn-group btn-group-sm" role="group" aria-label="Actions">
                                                    <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                                    <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Details</a>
                                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4">No investments found.</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-secondary">
                                    <td colspan="5" class="text-end fw-semibold">Grand Total</td>
                                    <td class="text-end fw-semibold">@totalSum.ToString("C")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-between align-items-center">
                    <div class="small text-muted">Showing @Model?.Count() ?? 0 investment(s)</div>
                    <div class="fw-semibold">Total Value: @totalSum.ToString("C")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Optional: add custom scripts here -->
}
