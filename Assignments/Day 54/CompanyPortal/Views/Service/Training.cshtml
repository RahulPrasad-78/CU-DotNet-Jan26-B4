
@{
    ViewData["Title"] = "Training";
}

<div class="container mt-5">

    <h2 class="text-center mb-4">Training Programs</h2>

    <div class="accordion" id="trainingAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#t1">
                    Web Development Training
                </button>
            </h2>

            <div id="t1" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    Learn modern web development including HTML, CSS, JavaScript, Bootstrap, and ASP.NET. This training focuses on building responsive and dynamic web applications used in real-world projects.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#t2">
                    Cloud & DevOps Training
                </button>
            </h2>

            <div id="t2" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Understand cloud computing platforms like AWS and Azure, along with DevOps practices such as CI/CD pipelines, containerization, and deployment automation.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#t3">
                    Data Science Training
                </button>
            </h2>

            <div id="t3" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Learn data analysis, visualization, and machine learning using Python tools such as Pandas, NumPy, and TensorFlow to extract insights from large datasets.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#t4">
                    Cyber Security Training
                </button>
            </h2>

            <div id="t4" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Learn how to protect systems and networks from cyber threats. Topics include ethical hacking, network security, encryption techniques, and security testing.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#t5">
                    Mobile App Development
                </button>
            </h2>

            <div id="t5" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Build Android and cross-platform mobile applications using modern frameworks and tools with a focus on UI design and performance optimization.
                </div>
            </div>
        </div>

    </div>

</div>