
@{
    ViewData["Title"] = "Consulting";
}

<div class="container mt-5">

    <h2 class="text-center mb-4">Consulting Services</h2>

    <div class="accordion" id="consultAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#c1">
                    Business Consulting
                </button>
            </h2>

            <div id="c1" class="accordion-collapse collapse show">
                <div class="accordion-body">
                    We help organizations improve business strategies, increase productivity, and optimize operations to achieve better results.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c2">
                    IT Consulting
                </button>
            </h2>

            <div id="c2" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Expert advice on software development, system architecture, and technology solutions to improve business efficiency.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c3">
                    Technology Consulting
                </button>
            </h2>

            <div id="c3" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Guidance on selecting and implementing modern technologies that support digital transformation and innovation.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c4">
                    Digital Transformation Consulting
                </button>
            </h2>

            <div id="c4" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Helping businesses adopt digital tools, cloud platforms, and automation to modernize their operations and services.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#c5">
                    Cyber Security Consulting
                </button>
            </h2>

            <div id="c5" class="accordion-collapse collapse">
                <div class="accordion-body">
                    Assessing security risks, implementing protection strategies, and helping organizations secure their systems and data.
                </div>
            </div>
        </div>

    </div>

</div>