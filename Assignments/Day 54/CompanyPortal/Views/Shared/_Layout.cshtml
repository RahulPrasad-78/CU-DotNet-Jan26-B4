<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title> @ViewData["Title"] -  CompanyPortal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CompanyPortal.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"> <img src="/img/chandigarh-university-logo-cu_freelogovectors.net_.png" height="25px" width="15px" /> CompanyPortal</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" 
                            asp-area="" asp-controller="Home" asp-action="Index" id="homeDropdown" role="button"
                            data-bs-toggle = "dropdown"
                            aria-expanded="false">Home</a>
                            <ul class="dropdown-menu" aria-labelledby="homeDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="Index">Index</a>
                                    <a class="dropdown-item" asp-controller="Home" asp-action="About">About</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" 
                            asp-area="" asp-controller="Service" asp-action="Index" id="homeDropdown" role="button"
                            data-bs-toggle = "dropdown"
                            aria-expanded="false">Service</a>
                            <ul class="dropdown-menu" aria-labelledby="homeDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Service" asp-action="Index">Index</a>
                                    <a class="dropdown-item" asp-controller="Service" asp-action="Consulting">Consulting</a>
                                    <a class="dropdown-item" asp-controller="Service" asp-action="Training">Training</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" 
                            asp-area="" asp-controller="Products" asp-action="Index" id="homeDropdown" role="button"
                            data-bs-toggle = "dropdown"
                            aria-expanded="false">Product</a>
                            <ul class="dropdown-menu" aria-labelledby="homeDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Products" asp-action="Index">Index</a>
                                    <a class="dropdown-item" asp-controller="Products" asp-action="Software">Software</a>
                                    <a class="dropdown-item" asp-controller="Products" asp-action="Tools">Tools</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" 
                            asp-area="" asp-controller="Contact" asp-action="Index" id="homeDropdown" role="button"
                            data-bs-toggle = "dropdown"
                            aria-expanded="false">Contact</a>
                            <ul class="dropdown-menu" aria-labelledby="homeDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Contact" asp-action="Index">Index</a>
                                </li>
                            </ul>
                        </li>
          
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CompanyPortal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
